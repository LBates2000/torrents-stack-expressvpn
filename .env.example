# WARNING: Do NOT put real secrets, passwords, or API keys in this file. Use placeholders only.
# Copy this file to .env and fill in your actual values. Never commit real secrets to version control.
# User/group
PUID=1000
PGID=1000
# Time zone
TZ=America/Los_Angeles

# Network
APP_NET_DRIVER=bridge

# Host bind mount directories
HOST_CONFIGS_DIR=./configs
HOST_DOWNLOADS_DIR=./downloads

# Jackett config
JACKETT_CFG_API_KEY=YOUR_JACKETT_API_KEY_HERE
JACKETT_CFG_ADMIN_PASSWORD=YOUR_JACKETT_ADMIN_PASSWORD_HERE
JACKETT_CFG_PORT=9117
JACKETT_CFG_LOCAL_BIND_ADDRESS=127.0.0.1
JACKETT_CFG_ALLOW_EXTERNAL=true
JACKETT_CFG_ALLOW_CORS=false
JACKETT_CFG_INSTANCE_ID=YOUR_JACKETT_INSTANCE_ID_HERE
JACKETT_CFG_BLACKHOLE_DIR=/downloads/watch
JACKETT_CFG_UPDATE_DISABLED=false
JACKETT_CFG_UPDATE_PRERELEASE=false
JACKETT_CFG_BASE_PATH_OVERRIDE=null
JACKETT_CFG_BASE_URL_OVERRIDE=null
JACKETT_CFG_CACHE_ENABLED=true
JACKETT_CFG_CACHE_TTL=2100
JACKETT_CFG_CACHE_MAX_RESULTS_PER_INDEXER=1000
JACKETT_CFG_FLARESOLVERR_URL=http://flaresolverr:8191
JACKETT_CFG_FLARESOLVERR_MAX_TIMEOUT=55000
JACKETT_CFG_OMDB_API_KEY=YOUR_OMDB_API_KEY_HERE
JACKETT_CFG_OMDB_API_URL=https://www.omdbapi.com/
JACKETT_CFG_PROXY_TYPE=0
JACKETT_CFG_PROXY_URL=null
JACKETT_CFG_PROXY_PORT=null
JACKETT_CFG_PROXY_USERNAME=null
JACKETT_CFG_PROXY_PASSWORD=null
JACKETT_CFG_PROXY_IS_ANONYMOUS=true

# Jackett options
JACKETT_AUTO_UPDATE=true
JACKETT_RUN_OPTS=

# FlareSolverr options
LOG_LEVEL=info
LOG_FILE=none
LOG_HTML=false
CAPTCHA_SOLVER=none

# ExpressVPN activation code (required for authentication)
EXPRESSVPN_ACTIVATION_CODE=YOUR_EXPRESSVPN_ACTIVATION_CODE_HERE
EXPRESSVPN_REGION=smart
EXPRESSVPN_PROTOCOL=auto
EXPRESSVPN_HEALTHCHECK_MODE=strict

# qBittorrent config
QBITTORRENT_CFG_AUTORUN_ENABLED=false
QBITTORRENT_CFG_AUTORUN_PROGRAM=
QBITTORRENT_CFG_SESSION_ADD_TORRENT_STOPPED=false
QBITTORRENT_CFG_SESSION_DEFAULT_SAVE_PATH=/downloads/
QBITTORRENT_CFG_SESSION_PORT=6881
QBITTORRENT_CFG_SESSION_QUEUEING_SYSTEM_ENABLED=true
QBITTORRENT_CFG_SESSION_SSL_PORT=4981
QBITTORRENT_CFG_SESSION_SHARE_LIMIT_ACTION=Stop
QBITTORRENT_CFG_SESSION_TEMP_PATH=/downloads/incomplete/
QBITTORRENT_CFG_LEGAL_NOTICE_ACCEPTED=true
QBITTORRENT_CFG_META_MIGRATION_VERSION=8
QBITTORRENT_CFG_NETWORK_COOKIES=@Invalid()
QBITTORRENT_CFG_NETWORK_PORT_FORWARDING_ENABLED=false
QBITTORRENT_CFG_PROXY_HOSTNAME_LOOKUP_ENABLED=false
QBITTORRENT_CFG_PROXY_PROFILE_BITTORRENT=true
QBITTORRENT_CFG_PROXY_PROFILE_MISC=true
QBITTORRENT_CFG_PROXY_PROFILE_RSS=true
QBITTORRENT_CFG_CONNECTION_PORT_RANGE_MIN=6881
QBITTORRENT_CFG_CONNECTION_UPNP=false
QBITTORRENT_CFG_DOWNLOADS_SAVE_PATH=/downloads/
QBITTORRENT_CFG_DOWNLOADS_TEMP_PATH=/downloads/incomplete/
QBITTORRENT_CFG_WEBUI_ADDRESS=0.0.0.0
QBITTORRENT_CFG_WEBUI_SERVER_DOMAINS=*
QBITTORRENT_CFG_WEBUI_PASSWORD_PLAINTEXT=null
# If null, a temporary password will be generated and echoed to the logs. Set this to your desired WebUI password to override.
QBITTORRENT_CFG_WEBUI_PASSWORD_PBKDF2=YOUR_WEBUI_PASSWORD_HASH_HERE

# qBittorrent Jackett search plugin bootstrap
QBITTORRENT_JACKETT_API_KEY=YOUR_QBITTORRENT_JACKETT_API_KEY_HERE
QBITTORRENT_JACKETT_URL=http://jackett:9117
QBITTORRENT_JACKETT_THREAD_COUNT=20
QBITTORRENT_JACKETT_TRACKER_FIRST=false
QBITTORRENT_JACKETT_PLUGIN_URL=https://raw.githubusercontent.com/qbittorrent/search-plugins/fa0be6abdc47b8622e8ec71a0d4427d9a7770eab/nova3/engines/jackett.py

# qBittorrent JSON config payloads (must be valid JSON objects)
QBITTORRENT_CFG_CATEGORIES_JSON=
QBITTORRENT_CFG_WATCHED_FOLDERS_JSON=

# Optional: container/image/port/dns overrides for advanced users
# HOST_EXPRESSVPN_ENTRYPOINT_SCRIPT=./scripts/expressvpn-entrypoint-fixed.sh
# CONTAINER_CONFIGS_DIR=/config
# CONTAINER_DOWNLOADS_DIR=/downloads
EXPRESSVPN_IMAGE_TAG=5.1.0.12141.69cfc6c3
FLARESOLVERR_IMAGE_TAG=v3.4.6
JACKETT_IMAGE_TAG=v0.24.1542-ls366
QBITTORRENT_IMAGE_TAG=5.1.4-r2-ls448
# EXPRESSVPN_CONTAINER_NAME=expressvpn
# FLARESOLVERR_CONTAINER_NAME=flaresolverr
# JACKETT_CONTAINER_NAME=jackett
# QBITTORRENT_CONTAINER_NAME=qbittorrent
# DNS1=8.8.8.8
# DNS2=1.1.1.1
# QBITTORRENT_WEBUI_PORT=8080
# QBITTORRENT_TORRENTING_PORT=6881
# JACKETT_PORT=9117
# FLARESOLVERR_PORT=8191
# HEALTHCHECK_INTERVAL=30s
# HEALTHCHECK_TIMEOUT=30s
# HEALTHCHECK_RETRIES=10
# HEALTHCHECK_START_PERIOD=180s

# Wrapper progress log defaults
# STACK_EXTERNAL_LOG_MODE=off
# STACK_EXTERNAL_LOG_RETENTION_DAYS=14
