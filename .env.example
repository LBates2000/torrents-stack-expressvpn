# User/group
PUID=1000
PGID=1000

# Time zone
TZ=Etc/UTC

# Network
APP_NET_DRIVER=bridge

# Pinned image tags (override if needed)
EXPRESSVPN_IMAGE_TAG=latest
FLARESOLVERR_IMAGE_TAG=latest
JACKETT_IMAGE_TAG=latest
QBITTORRENT_IMAGE_TAG=latest

# Container names
EXPRESSVPN_CONTAINER_NAME=expressvpn
FLARESOLVERR_CONTAINER_NAME=flaresolverr
JACKETT_CONTAINER_NAME=jackett
QBITTORRENT_CONTAINER_NAME=qbittorrent

# DNS used by expressvpn, jackett, and flaresolverr
DNS1=8.8.8.8
DNS2=1.1.1.1

# Published ports
QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_TORRENTING_PORT=6881
JACKETT_PORT=9117
FLARESOLVERR_PORT=8191

# Shared healthcheck defaults
HEALTHCHECK_INTERVAL=20s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=8
HEALTHCHECK_START_PERIOD=30s

# ExpressVPN basics
EXPRESSVPN_ACTIVATION_CODE=
EXPRESSVPN_SERVER=smart
EXPRESSVPN_PROTOCOL=auto
EXPRESSVPN_HEALTHCHECK_MODE=strict

# FlareSolverr options
LOG_LEVEL=info
LOG_FILE=none
LOG_HTML=false
CAPTCHA_SOLVER=none

# Jackett options
JACKETT_AUTO_UPDATE=true
JACKETT_RUN_OPTS=
