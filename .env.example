# User/group
PUID=1000
PGID=1000

# Time zone
TZ=Etc/UTC

# Pinned image tags (override if needed)
EXPRESSVPN_IMAGE_TAG=latest
FLARESOLVERR_IMAGE_TAG=latest
JACKETT_IMAGE_TAG=latest
QBITTORRENT_IMAGE_TAG=latest

# DNS used by expressvpn, jackett, and flaresolverr
DNS1=8.8.8.8
DNS2=1.1.1.1

# Published ports
QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_TORRENTING_PORT=6881
JACKETT_PORT=9117
FLARESOLVERR_PORT=8191

# ExpressVPN basics
EXPRESSVPN_ACTIVATION_CODE=
EXPRESSVPN_SERVER=smart
EXPRESSVPN_PROTOCOL=auto
